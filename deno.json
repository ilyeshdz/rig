{
  "name": "@hdzilyes/rig",
  "version": "0.1.1",
  "license": "MIT",
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "deno.json",
      "src/"
    ]
  },
  "exports": {
    ".": "./src/main.ts"
  },
  "tasks": {
    "dev": "deno run --watch src/main.ts",
    "test": "deno test tests/ --allow-read --allow-write --allow-env --allow-net",
    "bench": "deno bench tests/benchmarks/ --allow-read --allow-write --allow-env",
    "bench:plugins": "deno bench tests/benchmarks/official_plugins_bench.ts --allow-read --allow-write",
    "bench:core": "deno bench tests/benchmarks/deno_native_bench.ts tests/benchmarks/performance_bench.ts",
    "bench:manager": "deno bench tests/benchmarks/plugin_manager_bench.ts"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@1.0.0",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/toml": "jsr:@std/toml@^1.0.2",
    "marked": "npm:marked@^17.0.3"
  },
  "rig": {
    "contentDir": "content",
    "templateDir": "templates",
    "outputDir": "dist"
  }
}
